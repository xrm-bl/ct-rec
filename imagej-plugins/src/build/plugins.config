# Name: SP8CT_Filters
# Author: SP8CT project

Plugins>SP8CT>Filters, "Gaussian Filter 2D",            filters.Gaussian_Filter_2D
Plugins>SP8CT>Filters, "Gaussian Filter 3D",            filters.Gaussian_Filter_3D
Plugins>SP8CT>Filters, "Gaussian Filter 3D Ext",        filters.Gaussian_Filter_3D_Ext
Plugins>SP8CT>Filters, "Median Filter 2D",              filters.Median_Filter_2D
Plugins>SP8CT>Filters, "Median Filter 3D Ext",          filters.Median_Filter_3D_Ext
Plugins>SP8CT>Filters, "Bilateral Filter 2D",           filters.Bilateral_Filter_2D
Plugins>SP8CT>Filters, "Bilateral Filter 3D Ext",       filters.Bilateral_Filter_3D_Ext
Plugins>SP8CT>Filters, "NLM Filter 2D",                 filters.NLM_Filter_2D
Plugins>SP8CT>Filters, "NLM Filter 3D Ext",             filters.NLM_Filter_3D_Ext
Plugins>SP8CT>Filters, "TV Denoise 2D",                 filters.TV_Denoise_2D
Plugins>SP8CT>Filters, "TV Denoise 3D Ext",             filters.TV_Denoise_3D_Ext
Plugins>SP8CT>Filters, "Wavelet Denoise 2D",            filters.Wavelet_Denoise_2D
Plugins>SP8CT>Filters, "Wavelet Denoise 3D Ext",        filters.Wavelet_Denoise_3D_Ext
Plugins>SP8CT>Filters, "Anisotropic Diffusion 2D",      filters.Anisotropic_Diffusion_2D
Plugins>SP8CT>Filters, "Anisotropic Diffusion 3D Ext",  filters.Anisotropic_Diffusion_3D_Ext
Plugins>SP8CT>Filters, "BM3D Filter 2D",                filters.BM3D_Filter_2D
Plugins>SP8CT>Filters, "BM4D Filter 3D Ext",            filters.BM4D_Filter_3D_Ext

# Name: SP8CT_Tools
# Author: SP8CT project

Plugins>SP8CT>Tools, "Stack Crop 3D",  tools.Stack_Crop_3D

# Name: SP8CT_IO
# Author: SP8CT project

Plugins>SP8CT>IO, "Open HIS/IMG...",   io.Open_HIS_IMG
