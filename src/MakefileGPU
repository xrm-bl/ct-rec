# MakefileGPU (Linux/gcc + nvcc) version
# Usage: make all
# Individual GPU targets: make ct_rec_g hp_tg_g tf_tg_g etc.
#
# CUDA 13.x: Maxwell/Pascal/Volta removed.  Minimum arch is sm_75 (Turing).
#   Default below is -arch=all-major (broadest portability).  Override
#   CUDA_ARCH on the command line to target a single GPU (faster build):
#     make all CUDA_ARCH="-arch=sm_86"     (Ampere, e.g. RTX A6000)
#     make all CUDA_ARCH="-arch=sm_89"     (Ada Lovelace)
#     make all CUDA_ARCH="-arch=sm_100"    (Blackwell)

CC      = gcc
CFLAGS  = -O2 -D_USE_MATH_DEFINES
OMPF    = -fopenmp
LIBS    = -lm
TIFFLIB = -ltiff
CBP     = cbp_thread_int.c
SIF_F   = sif_f_fast.c

CUDA_HOME ?= /usr/local/cuda
CUDAINCL  = $(CUDA_HOME)/include
CUDALIB   = $(CUDA_HOME)/lib64
CUDART    = -L$(CUDALIB) -lcudart
CUFFT     = -L$(CUDALIB) -lcufft

# Default: -arch=all-major (one native cubin per supported major + PTX fallback).
#   Portable across all CUDA 13.x archs (sm_75/80/90/100/120...).
#   A6000 (sm_86) runs the sm_80 cubin via same-major binary compatibility.
#   For fast iterative builds on a single known GPU, override e.g.
#   "make all CUDA_ARCH=-arch=sm_86" (A6000) to skip the extra cubins.
CUDA_ARCH ?= -arch=all-major

NVCCFLAGS = -O3 -I$(CUDAINCL) $(CUDA_ARCH) -use_fast_math -Xcompiler "-Wno-unused-result"

EXE_DIR = ../bin

.PHONY: all clean ct_rec_g tf_rec_g hp_tg_g tf_tg_g \
        ofct_srec_g otf_rec_g oftf_srec_g p_rec_g filters_g

all: ct_rec_g tf_rec_g hp_tg_g tf_tg_g \
     ofct_srec_g otf_rec_g oftf_srec_g p_rec_g filters_g

# ---------------------------------------------------------------
# GPU ring removal object (pure CUDA C; no Thrust, no -lstdc++)
# ---------------------------------------------------------------
sort_filter_g.o: sort_filter_g.cu sort_filter_g.h
	nvcc $(NVCCFLAGS) -c sort_filter_g.cu -o sort_filter_g.o

# ---------------------------------------------------------------
# Normal CT reconstruction (GPU)
# ---------------------------------------------------------------
ct_rec_g: ct_rec_g_r ct_rec_g_s ct_rec_g_c

ct_rec_g_r: sort_filter_g.o
	nvcc $(NVCCFLAGS) cbp.cu -DFloat=float -c -DFilter=Ramachandran -o cbp.o
	$(CC) $(CFLAGS) $(OMPF) -DUSE_GPU -o $(EXE_DIR)/ct_rec_g_r ct_rec.c error.c sort_filter_g.o $(SIF_F) cbp.o $(CUFFT) $(CUDART) -lstdc++ $(LIBS)
ct_rec_g_s: sort_filter_g.o
	nvcc $(NVCCFLAGS) cbp.cu -DFloat=float -c -DFilter=Shepp -o cbp.o
	$(CC) $(CFLAGS) $(OMPF) -DUSE_GPU -o $(EXE_DIR)/ct_rec_g_s ct_rec.c error.c sort_filter_g.o $(SIF_F) cbp.o $(CUFFT) $(CUDART) -lstdc++ $(LIBS)
ct_rec_g_c: sort_filter_g.o
	nvcc $(NVCCFLAGS) cbp.cu -DFloat=float -c -DFilter=Chesler -o cbp.o
	$(CC) $(CFLAGS) $(OMPF) -DUSE_GPU -o $(EXE_DIR)/ct_rec_g_c ct_rec.c error.c sort_filter_g.o $(SIF_F) cbp.o $(CUFFT) $(CUDART) -lstdc++ $(LIBS)

