# Makefile (CPU) - Linux/GCC version
# Usage: make all
# Individual targets: make tif_blf tif_gsf tif_mdf etc.

CC      = gcc
CFLAGS  = -O2 -D_USE_MATH_DEFINES
OMPF    = -fopenmp
AVXF    = -mavx2
LIBS    = -lm
TIFFLIB = -ltiff
CBP     = cbp_thread_int.c
CBPd    = cbp_thread_nai.c
SIF_F   = sif_f_fast.c

EXE_DIR = ../bin

.PHONY: all clean ct_rec hp_tg ofct_srec otct_rec \
        p_rec sf_rec misc si_tools filters

all: ct_rec hp_tg ofct_srec otct_rec \
     p_rec sf_rec misc si_tools filters

# ---------------------------------------------------------------
# Normal CT reconstruction
# ---------------------------------------------------------------
ct_rec: ct_rec_t_r ct_rec_t_s ct_rec_t_c
ct_rec_t_r:
	$(CC) $(CFLAGS) $(OMPF) -o $(EXE_DIR)/ct_rec_t_r ct_rec_c.c error.c sort_filter_omp.c $(SIF_F) $(TIFFLIB) $(CBP) -DFilter=Ramachandran $(LIBS)
ct_rec_t_s:
	$(CC) $(CFLAGS) $(OMPF) -o $(EXE_DIR)/ct_rec_t_s ct_rec_c.c error.c sort_filter_omp.c $(SIF_F) $(TIFFLIB) $(CBP) -DFilter=Shepp $(LIBS)
ct_rec_t_c:
	$(CC) $(CFLAGS) $(OMPF) -o $(EXE_DIR)/ct_rec_t_c ct_rec_c.c error.c sort_filter_omp.c $(SIF_F) $(TIFFLIB) $(CBP) -DFilter=Chesler $(LIBS)

